{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Rifteo",
  "colors": {
    "primary": "#D4AF37",
    "light": "#E6C75A",
    "dark": "#B8860B"
  },
  "favicon": "/rifteo-logo-light.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": ["welcome", "your-role", "glossary"]
      },
      {
        "group": "Your Audit Results",
        "pages": [
          "results",
          "findings-dashboard", 
          "asset-inventory",
          "responding-to-findings"
        ]
      },
      {
        "group": "Attack Surface Management",
        "pages": ["what-is-asm", "activating-scans", "scheduling-results"]
      },
      {
        "group": "Teo AI",
        "pages": ["teo-recommendations"]
      },
      {
        "group": "Reports",
        "pages": ["generating-reports", "asm-reports"]
      },
      {
        "group": "Your Account",
        "pages": [
          "dashboard",
          "notifications",
          "team-management",
          "contact-support"
        ]
      },
      {
        "group": "What's New",
        "pages": ["changelog"]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@rifteo.fr"
      }
    ],
    "primary": {
